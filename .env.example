# =============================================================================
# Edstellar Conflict Checker — environment template
# Copy to `.env` (local) or set in Vercel → Project → Settings → Environment Variables.
# Minimum to run the checker: DATABASE_URL + (GROQ_API_KEY or ANTHROPIC_API_KEY).
# =============================================================================

# ---- Database (REQUIRED) ----------------------------------------------------
# Neon Postgres pooled connection string. Get one free at https://neon.tech.
# The `db:setup` script enables pgvector + creates all tables.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# ---- Chat provider (pick ONE; Groq is the default) --------------------------
AI_CHAT_PROVIDER=groq        # groq | claude | openai

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# ---- Embeddings (default: local, no key needed) -----------------------------
# `local` downloads bge-small-en-v1.5 (384-dim) on first use.
# Switching to `openai` requires re-ingesting the corpus AND widening
# pages.embedding to vector(1536) — see README "Switching embeddings".
AI_EMBED_PROVIDER=local       # local | openai
OPENAI_EMBED_MODEL=text-embedding-3-small

# ---- Google Search Console (OAuth, optional) --------------------------------
# Used by /search-console and to enrich match rows with GSC metrics.
# In Google Cloud Console: create an OAuth 2.0 Web Client + enable Search Console API.
# Add the redirect URI below to the client's "Authorized redirect URIs".
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/gsc/callback
GSC_SITE_URL=https://www.edstellar.com/

# ---- Competitor SERP research (optional) ------------------------------------
# https://serper.dev — used by /competitors and SERP-overlap features.
SERPER_API_KEY=

# ---- App config -------------------------------------------------------------
# Public base URL of the deployed app. Used to build absolute links in cron
# jobs and OAuth redirects when running on Vercel.
APP_BASE_URL=http://localhost:3000

# Comma-separated brand/keyword terms the checker treats as house terms.
BRAND_TERMS=edstellar,edstellar.com

# Shared secret REQUIRED by /api/cron/* routes (pass via
# `Authorization: Bearer <CRON_SECRET>`).
#
# Session 6 audit (S1): the routes now fail CLOSED — missing/mismatched
# secret returns 401. Vercel Cron sends this header automatically when
# CRON_SECRET is configured at Project → Settings → Environment Variables.
# A blank value in production = every cron run 401s = silent breakage.
CRON_SECRET=change-me-to-a-long-random-string

# Optional API key gating the LLM-burning endpoints from external callers
# (e.g. a CMS pre-publish hook). When set, callers must send
# `X-API-Key: <WEBHOOK_API_KEY>`. Gates THREE endpoints:
#   - POST /api/check
#   - POST /api/summarize          (added Session 6 — formerly unauth'd)
#   - POST /api/rewrite-suggestion (added Session 6 — formerly unauth'd)
# Leave blank and the endpoints rely on per-IP rate-limiting instead.
WEBHOOK_API_KEY=

# Optional tuning — Session 6 audit (H11): raised the default conflict
# floor from 0.30 to 0.50 cosine so results stay above the documented
# noise band. Override here without redeploying code if a team finds it
# too aggressive. Number between 0 and 1.
# CONFLICT_MIN_SIMILARITY=0.50

# ---- NextAuth (Google SSO) — opt-in ----------------------------------------
# Leave AUTH_ENABLED unset/false to keep the dashboard open (current default).
# Flip to "true" once the OAuth consent screen is moved out of testing mode
# in Google Cloud Console AND the new redirect URI is whitelisted there.
#
# Required when AUTH_ENABLED=true:
#   - AUTH_SECRET — long random string (`openssl rand -hex 32` or equivalent)
#   - GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET (reuse from the GSC OAuth client
#     or create a new one). In Google Cloud Console, ADD this redirect URI:
#       https://<prod-host>/api/auth/callback/google
#
# Session 6 audit (S2): AUTH_SECRET is ALSO used to sign the GSC OAuth
# state nonce — recommended to set even when AUTH_ENABLED=false so the
# /api/gsc/callback CSRF check uses a dedicated key (falls back to
# GOOGLE_CLIENT_SECRET if AUTH_SECRET is missing in production).
#
# Optional:
#   - AUTH_ALLOWED_DOMAINS — comma-separated email-domain allow-list. Defaults
#     to "edstellar.com". Email addresses outside the list bounce on sign-in.
#   - AUTH_TRUST_HOST — Session 6 audit (H4): auth.ts auto-trusts the host
#     inside Vercel (via the VERCEL env). Outside Vercel, set this to "true"
#     to opt in explicitly; leave blank/false to reject host-header spoofing.
AUTH_ENABLED=false
AUTH_SECRET=
AUTH_ALLOWED_DOMAINS=edstellar.com
# AUTH_TRUST_HOST=true
